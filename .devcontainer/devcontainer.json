{
  "name": "Book Shelf Development with Claude Code",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",

  // Claude Code Feature を使用してインストール
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },

  // Claude Code設定を永続化するためのボリュームマウント
  "mounts": [
    "source=claude-code-config,target=/home/vscode/.claude,type=volume"
  ],

  // 環境変数（.envファイルから読み込み推奨）
  // HOME: Windows(WSL)環境ではvscodeユーザーのUIDがrootと衝突し、
  // $HOMEが/rootに解決されてしまうため、明示的に/home/vscodeへ固定する
  // （/home/vscode/.claude はボリュームマウントで永続化されている）
  "containerEnv": {
    "DISABLE_AUTOUPDATER": "0",
    "HOME": "/home/vscode"
  },

  // ~/.claude.json (認証情報を含む) はボリューム外のファイルなので、
  // ボリューム内に保存してシンボリックリンクすることでリビルド後も認証状態を維持する
  // バックエンドの依存パッケージ（uv sync）もコンテナ作成時にインストールする
  "postCreateCommand": "if [ -f ~/.claude.json ] && [ ! -L ~/.claude.json ]; then mv ~/.claude.json ~/.claude/claude.json; fi; ln -sf ~/.claude/claude.json ~/.claude.json; cd /workspaces/book-shelf/backend && uv sync",

  // コンテナ起動時（再起動含む）に依存パッケージを最新化する
  "postStartCommand": "cd /workspaces/book-shelf/backend && uv sync",

  // ポート転送（必要に応じて追加）
  "forwardPorts": [8000],

  // VS Code拡張機能（推奨）
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "bierner.markdown-mermaid"
      ]
    }
  }
}
